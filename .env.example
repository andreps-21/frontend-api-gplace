# Gplace — frontend Next.js (consome api-gplace)
# Copiar para .env.local na raiz deste projeto e reiniciar: npm run dev
#
# API Laravel (repositório api-gplace), prefixo /api/v1:
#   Docker: ./docker-start.sh → http://localhost:8005
#   Cabeçalho `app` é obrigatório (middleware CheckAppHeader): usa o campo app_token da loja (tabela stores).

# Local (Docker api-gplace, porta 8005). Em produção (ex.: Vercel) OBRIGATÓRIO: URL HTTPS pública da API, nunca localhost.
NEXT_PUBLIC_API_URL=http://localhost:8005/api/v1
# Produção (Gooding): NEXT_PUBLIC_API_URL=https://api-gplace.gooding.solutions/api/v1

# Em local, `php artisan db:seed` cria loja com token fixo (LocalDevStoreSeeder). Em produção, usar o app_token real da loja.
NEXT_PUBLIC_APP_TOKEN=gplace-local-frontend

NEXT_PUBLIC_APP_NAME=Gplace
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Opcional: ver dashboard + sidebar sem login/API (só desenvolvimento; não usar em produção).
# NEXT_PUBLIC_UI_PREVIEW=true
