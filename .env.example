# frontend-tim — variáveis de ambiente (exemplo)
# Copia para desenvolvimento local:  cp .env.example .env.local
# Reinicia o servidor depois:  npm run dev
#
# A API Laravel (api-tim) expõe as rotas em /api/v1 (bootstrap + routes/api.php).

# --- api-tim em Docker (raiz do repositório: ./docker-start.sh → app em http://localhost:8080)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- api-tim com PHP por CLI (na pasta da API: php artisan serve → porta 8000 por omissão)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# --- API remota (só se precisares de ambiente alinhado à produção)
# NEXT_PUBLIC_API_URL=https://api.alpharstelecom.com.br/api/v1

# Versão opcional no UI (ver lib/use-update-notification.ts)
# NEXT_PUBLIC_APP_VERSION=1.0.0
